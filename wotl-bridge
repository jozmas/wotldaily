/**
 * WOTLdaily - Content Bridge Engine
 * PURPOSE:
 * This script fetches daily liturgical readings (Gospel & Psalm) in English.
 * It injects the content into the main website at wotl.infinityfree.me.
 * TTS functionality is handled by the host website.
 */

async function loadDailyContent() {
    const gospelContainer = document.getElementById('gospel-content');
    const psalmContainer = document.getElementById('psalm-content');
    const dateContainer = document.getElementById('gospel-date');

    // 1. Set Global Date (English)
    const today = new Date();
    const y = today.getFullYear();
    const m = String(today.getMonth() + 1).padStart(2, '0');
    const d = String(today.getDate()).padStart(2, '0');

    if (dateContainer) {
        dateContainer.innerText = today.toLocaleDateString('en-US', { 
            weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' 
        });
    }

    try {
        // 2. Fetch Liturgical Reference
        const litResponse = await fetch(`https://cpbjr.github.io/catholic-readings-api/readings/${y}/${m}-${d}.json`);
        if (!litResponse.ok) throw new Error("Liturgical API unreachable");
        
        const litData = await litResponse.json();
        
        // 3. Process Gospel
        const gospelEntry = litData.readings.find(r => r.type === 'gospel');
        if (gospelEntry && gospelContainer) {
            await injectScripture(gospelEntry.reference, gospelContainer, 'Holy Gospel');
        }

        // 4. Process Psalm
        const psalmRef = litData.readings.find(r => r.type === 'psalm')?.reference || litData.readings.responsorial_psalm;
        if (psalmRef && psalmContainer) {
            await injectScripture(psalmRef, psalmContainer, 'Responsorial Psalm');
        }

    } catch (error) {
        console.error("WOTL Bridge Error:", error);
    }
}

/**
 * Fetches text from Bible API and injects it into a target element
 */
async function injectScripture(reference, container, label) {
    try {
        const cleanRef = reference.split('(')[0].trim();
        const response = await fetch(`https://bible-api.com/${encodeURIComponent(cleanRef)}?translation=kjv`);
        if (!response.ok) return;
        
        const data = await response.json();
        
        container.innerHTML = `
            <div class="animate-fade-in">
                <h3 class="font-serif text-xl text-bible-gold mb-2 uppercase tracking-widest">${label}</h3>
                <h4 class="text-white font-bold mb-4 text-lg">${reference}</h4>
                <div class="text-gray-300 italic leading-relaxed">
                    "${data.text.trim()}"
                </div>
            </div>
        `;
    } catch (e) {
        console.error(`Error injecting ${label}:`, e);
    }
}

// Initialize on load
window.addEventListener('DOMContentLoaded', loadDailyContent);
