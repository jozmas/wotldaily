/**
 * WOTLdaily - Gospel Bridge Engine (Stable Version)
 * Táto verzia nepoužíva Universalis (kvôli CORS chybám), 
 * ale kombinuje Catholic Readings API a Bible API.
 */

async function loadDailyGospel() {
    const gospelContainer = document.getElementById('gospel-content');
    const dateContainer = document.getElementById('gospel-date');
    const audioControls = document.getElementById('audio-controls');

    if (!gospelContainer) return;

    // 1. Nastavenie dátumu (Anglicky)
    const today = new Date();
    const y = today.getFullYear();
    const m = String(today.getMonth() + 1).padStart(2, '0');
    const d = String(today.getDate()).padStart(2, '0');

    if (dateContainer) {
        dateContainer.innerText = today.toLocaleDateString('en-US', { 
            weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' 
        });
    }

    try {
        // 2. Získanie referencie evanjelia z Catholic Readings API
        // Toto API je verejné a dostupné pre JS
        const litResponse = await fetch(`https://cpbjr.github.io/catholic-readings-api/readings/${y}/${m}-${d}.json`);
        if (!litResponse.ok) throw new Error("Liturgical API unavailable");
        
        const litData = await litResponse.json();
        
        // Hľadáme evanjelium v poli čítaní
        const gospelReading = litData.readings.find(r => r.type === 'gospel');
        if (!gospelReading) throw new Error("Gospel reference not found for today");

        const reference = gospelReading.reference;

        // 3. Získanie samotného textu z Bible API (KJV translation)
        const bibleResponse = await fetch(`https://bible-api.com/${encodeURIComponent(reference)}?translation=kjv`);
        if (!bibleResponse.ok) throw new Error("Bible API unavailable");
        
        const bibleData = await bibleResponse.json();

        // 4. Zobrazenie na stránke
        gospelContainer.innerHTML = `
            <div class="prose-custom animate-fade-in text-center md:text-left">
                <h3 class="font-serif text-2xl text-white mb-6 underline decoration-bible-gold/30 underline-offset-8">
                    ${reference}
                </h3>
                <div class="gospel-body text-gray-300 leading-relaxed text-lg italic bg-white/5 p-6 rounded-2xl border-l-4 border-bible-gold shadow-inner">
                    "${bibleData.text.trim()}"
                </div>
                <p class="mt-4 text-[10px] uppercase tracking-widest text-gray-500 font-sans">
                    Source: Catholic Readings API & Bible-API (KJV)
                </p>
            </div>
        `;
        
        // Audio nastavenia
        if (audioControls) audioControls.classList.remove('hidden');
        setupAudio(bibleData.text);

    } catch (error) {
        console.error("WOTL Bridge Error:", error);
        gospelContainer.innerHTML = `
            <div class="text-center py-10">
                <i class="fa-solid fa-circle-exclamation text-bible-gold/50 text-3xl mb-4"></i>
                <p class="text-gray-500 font-sans uppercase text-xs tracking-widest">
                    The Word is temporarily unavailable. <br>Please check our YouTube channel.
                </p>
            </div>
        `;
    }
}

function setupAudio(textToRead) {
    const readBtn = document.getElementById('readGospelBtn');
    const stopBtn = document.getElementById('stopGospelBtn');
    const synth = window.speechSynthesis;

    if (readBtn) {
        readBtn.onclick = () => {
            synth.cancel();
            const utterance = new SpeechSynthesisUtterance(textToRead);
            utterance.lang = 'en-US'; // Anglický hlas
            utterance.rate = 0.9;
            
            // Výber hlasu
            const voices = synth.getVoices();
            const preferredVoice = voices.find(v => v.lang.startsWith('en') && v.name.includes('Female')) || voices.find(v => v.lang.startsWith('en'));
            if (preferredVoice) utterance.voice = preferredVoice;

            synth.speak(utterance);
        };
    }

    if (stopBtn) {
        stopBtn.onclick = () => synth.cancel();
    }
}

// Spustenie
window.addEventListener('DOMContentLoaded', loadDailyGospel);
// Niektoré prehliadače potrebujú voice list až po loadnutí
window.speechSynthesis.onvoiceschanged = () => {};
